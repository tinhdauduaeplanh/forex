  "skills.backtesting.metrics": {
    "name": "skills.backtesting.metrics",
    "description": "Calculate backtesting performance metrics such as return and Sharpe ratio.",
    "version": "1.0.0",
    "category": "backtesting",
    "inputs": [
      {
        "name": "start_balance",
        "description": "Starting account balance.",
