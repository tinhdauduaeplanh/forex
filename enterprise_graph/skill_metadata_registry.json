      },
      {
        "name": "end_balance",
        "description": "Ending account balance.",
        "data_type": "float",
        "required": true,
        "example": 11000.0
      },
      {
        "name": "returns",
        "description": "Sequence of period returns.",
        "data_type": "List[float]",
        "required": false,
        "example": [
          0.01,
          0.02,
          -0.005
        ]
      },
      {
        "name": "risk_free_rate",
        "description": "Risk-free return rate for Sharpe ratio calculation.",
        "data_type": "float",
        "required": false,
        "example": 0.0
